# shell-app – variables de ejemplo (copiar a .env.local; no subir secretos)

# Supabase (público en cliente)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# Sentry – proyecto "shell-app"
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT

# Opcional
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_ORG=sha-de-venezuela
# SENTRY_PROJECT=shell-app

# Servicios Técnicos
NEXT_PUBLIC_SERVICIOS_URL=https://st.shadevenezuela.com.ve
# SERVICIOS_INTERNAL_URL=http://sha-servicios-app:3000

# ExchangeRate-API (USD→VES para requisiciones)
EXCHANGERATE_API_KEY=your_key_here

# Token de build para subir source maps (también válido en .env.local para next build)
# SENTRY_AUTH_TOKEN=sntrys_...
